# =============================================================================
# PostgreSQL Database Configuration (пункт 3)
# =============================================================================

POSTGRES_USER=airflow_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=airflow_db
POSTGRES_PORT=5432

# =============================================================================
# Airflow Configuration
# =============================================================================

# Airflow webserver port
AIRFLOW_WEBSERVER_PORT=8080

# Secret key for Airflow (generate with: openssl rand -hex 32)
AIRFLOW_SECRET_KEY=your_random_secret_key_min_32_chars_here

# Airflow UID (for file permissions)
AIRFLOW_UID=50000

# =============================================================================
# Airflow Admin User (for initial setup)
# =============================================================================

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin_password_here
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User

# =============================================================================
# Additional Settings
# =============================================================================

TZ=UTC
PYTHONUNBUFFERED=1
