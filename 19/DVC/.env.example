# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================

POSTGRES_USER=lakefs_user
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=lakefs_db
POSTGRES_PORT=5432

# =============================================================================
# MinIO S3 Storage Configuration
# =============================================================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Bucket for LakeFS data
MINIO_LAKEFS_BUCKET=lakefs-data

# =============================================================================
# LakeFS Configuration
# =============================================================================

LAKEFS_PORT=8000

# Auth secret key (minimum 32 characters)
# Generate with: openssl rand -base64 32
LAKEFS_AUTH_SECRET_KEY=your-random-secret-key-min-32-chars-long-change-in-production

# =============================================================================
# Additional Settings
# =============================================================================

TZ=UTC
