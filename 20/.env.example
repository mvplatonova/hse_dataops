# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================

POSTGRES_USER=mlflow_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=mlflow_db
POSTGRES_PORT=5432

# =============================================================================
# MLFlow Configuration
# =============================================================================

MLFLOW_PORT=5000

# =============================================================================
# Additional Settings
# =============================================================================

# Timezone
TZ=UTC

# Python unbuffered output
PYTHONUNBUFFERED=1
